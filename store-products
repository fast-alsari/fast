<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0">

<title>
منتجات المتجر
</title>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<link
href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;700;800&display=swap"
rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Cairo',sans-serif;
}

body{
background:#f5f6fa;
padding:15px;
padding-bottom:120px;
overflow-x:hidden;
}

.header{
background:
linear-gradient(
135deg,
#ff8800,
#ff5500
);

padding:24px 20px;
border-radius:28px;
color:white;

display:flex;
justify-content:space-between;
align-items:center;

margin-bottom:20px;

box-shadow:
0 8px 25px rgba(0,0,0,.10);
}

.header h2{
font-size:26px;
margin-bottom:6px;
}

.header p{
font-size:14px;
opacity:.95;
}

.add-btn{
width:58px;
height:58px;
border:none;
border-radius:20px;
background:white;
color:#ff6600;
font-size:22px;
cursor:pointer;
font-weight:bold;
}

.search-box{
background:white;
padding:14px 16px;
border-radius:18px;
display:flex;
align-items:center;
gap:10px;

margin-bottom:18px;

box-shadow:
0 5px 18px rgba(0,0,0,.05);
}

.search-box input{
border:none;
outline:none;
width:100%;
font-size:15px;
background:transparent;
}

.products-grid{
display:flex;
flex-direction:column;
gap:16px;
}

.product-card{
background:white;
padding:14px;
border-radius:26px;

display:flex;
gap:14px;

box-shadow:
0 5px 18px rgba(0,0,0,.06);
}

.product-image{
width:110px;
height:110px;
border-radius:20px;
object-fit:cover;
background:#eee;
flex-shrink:0;
}

.product-content{
flex:1;
}

.product-top{
display:flex;
justify-content:space-between;
align-items:flex-start;
gap:10px;
margin-bottom:8px;
}

.product-name{
font-size:18px;
font-weight:bold;
line-height:1.5;
}

.product-price{
font-size:18px;
font-weight:bold;
color:#ff6600;
margin-bottom:10px;
}

.product-description{
font-size:13px;
color:#666;
line-height:1.8;
margin-bottom:12px;
}

.status-row{
display:flex;
align-items:center;
gap:10px;
margin-bottom:12px;
}

.status-badge{
padding:6px 12px;
border-radius:12px;
font-size:12px;
font-weight:bold;
}

.active-status{
background:#e8fff3;
color:#00a86b;
}

.hidden-status{
background:#fff1f1;
color:#e53935;
}

.actions{
display:flex;
gap:10px;
flex-wrap:wrap;
}

.actions button{
flex:1;
height:46px;
border:none;
border-radius:16px;
font-size:14px;
font-weight:bold;
cursor:pointer;
}

.edit-btn{
background:#2563eb;
color:white;
}

.toggle-btn{
background:#ff8800;
color:white;
}

.delete-btn{
background:#e53935;
color:white;
}

.empty{
background:white;
padding:50px 20px;
border-radius:24px;
text-align:center;
font-size:16px;
color:#777;
}

.modal{
position:fixed;
inset:0;

background:rgba(0,0,0,.45);

display:none;
align-items:center;
justify-content:center;

padding:15px;

z-index:99999;
}

.modal-box{
background:white;
width:100%;
max-width:500px;

padding:22px;
border-radius:28px;
}

.modal-title{
font-size:22px;
font-weight:bold;
margin-bottom:18px;
color:#ff6600;
}

.input-group{
margin-bottom:15px;
}

.input-group label{
display:block;
margin-bottom:8px;
font-size:14px;
font-weight:bold;
}

.input-group input,
.input-group textarea{
width:100%;
border:none;
outline:none;

background:#f7f7f7;

padding:15px;
border-radius:18px;

font-size:15px;
}

.input-group textarea{
height:110px;
resize:none;
}

.save-btn{
width:100%;
height:56px;
border:none;
border-radius:18px;

background:
linear-gradient(
135deg,
#00b894,
#00a383
);

color:white;
font-size:16px;
font-weight:bold;
cursor:pointer;
}

.close-btn{
width:100%;
height:50px;
border:none;
border-radius:18px;

background:#eee;

margin-top:10px;

font-size:15px;
font-weight:bold;
cursor:pointer;
}

.bottom-bar{
position:fixed;
bottom:0;
left:0;
right:0;

height:82px;

background:white;

display:flex;
justify-content:space-around;
align-items:center;

box-shadow:
0 -5px 18px rgba(0,0,0,.08);

z-index:9999;
}

.nav-item{
display:flex;
flex-direction:column;
align-items:center;
gap:5px;

font-size:13px;
font-weight:bold;

color:#888;
cursor:pointer;
}

.nav-item.active{
color:#ff8800;
}

.nav-item i{
font-size:22px;
}

</style>

</head>

<body>

<div class="header">

<div>

<h2>
المنتجات
</h2>

<p>
إدارة منتجات المتجر
</p>

</div>

<button
class="add-btn"
onclick="openAddModal()">

<i class="fa-solid fa-plus"></i>

</button>

</div>

<div class="search-box">

<i class="fa-solid fa-magnifying-glass"></i>

<input
type="text"
id="searchInput"
placeholder="ابحث عن منتج">

</div>

<div
id="productsContainer"
class="products-grid"></div>

<!-- نافذة -->

<div
class="modal"
id="productModal">

<div class="modal-box">

<div
class="modal-title"
id="modalTitle">

إضافة منتج

</div>

<div class="input-group">

<label>
اسم المنتج
</label>

<input
type="text"
id="productName">

</div>

<div class="input-group">

<label>
السعر
</label>

<input
type="number"
id="productPrice">

</div>

<div class="input-group">

<label>
رابط الصورة
</label>

<input
type="text"
id="productImage">

</div>

<div class="input-group">

<label>
الوصف
</label>

<textarea
id="productDescription"></textarea>

</div>

<button
class="save-btn"
onclick="saveProduct()">

حفظ المنتج

</button>

<button
class="close-btn"
onclick="closeModal()">

إغلاق

</button>

</div>

</div>

<div class="bottom-bar">

<div
class="nav-item"
onclick="window.location.href='store-orders.html'">

<i class="fa-solid fa-bag-shopping"></i>

<span>
الطلبات
</span>

</div>

<div class="nav-item active">

<i class="fa-solid fa-box"></i>

<span>
المنتجات
</span>

</div>

<div
class="nav-item"
onclick="window.location.href='store-account.html'">

<i class="fa-solid fa-store"></i>

<span>
الحساب
</span>

</div>

</div>

<script type="module">

import { db }
from "./firebase.js";

import {

ref,
set,
push,
update,
remove,
onValue

}

from
"https://www.gstatic.com/firebasejs/12.13.0/firebase-database.js";

const currentUser =
JSON.parse(
localStorage.getItem("user")
);

if(
!currentUser ||
currentUser.type !== "store"
){

window.location.replace(
"index.html"
);

}

const productsRef =
ref(
db,
"store_products/" + currentUser.id
);

const container =
document.getElementById(
"productsContainer"
);

let allProducts = [];

let editId = null;

// =====================
// تحميل المنتجات
// =====================

onValue(
productsRef,
(snapshot)=>{

allProducts = [];

container.innerHTML = "";

if(snapshot.exists()){

const data =
snapshot.val();

for(let key in data){

allProducts.push({

id:key,
...data[key]

});

}

renderProducts(allProducts);

}else{

container.innerHTML = `
<div class="empty">
لا توجد منتجات
</div>
`;

}

}
);

// =====================
// عرض المنتجات
// =====================

function renderProducts(products){

container.innerHTML = "";

if(products.length === 0){

container.innerHTML = `
<div class="empty">
لا توجد نتائج
</div>
`;

return;

}

products.reverse().forEach(product=>{

container.innerHTML += `

<div class="product-card">

<img
src="${
product.image || 'product.png'
}"
class="product-image"
onerror="this.src='product.png'">

<div class="product-content">

<div class="product-top">

<div>

<div class="product-name">
${product.name || ""}
</div>

<div class="product-price">
${Number(
product.price || 0
).toLocaleString()} د.ع
</div>

</div>

</div>

<div class="product-description">

${product.description || "لا يوجد وصف"}

</div>

<div class="status-row">

<div class="
status-badge
${product.isHidden ? 'hidden-status' : 'active-status'}
">

${product.isHidden ? 'مخفي' : 'ظاهر'}

</div>

</div>

<div class="actions">

<button
class="edit-btn"
onclick="editProduct('${product.id}')">

تعديل

</button>

<button
class="toggle-btn"
onclick="toggleProduct('${product.id}')">

${product.isHidden ? 'إظهار' : 'إخفاء'}

</button>

<button
class="delete-btn"
onclick="deleteProduct('${product.id}')">

حذف

</button>

</div>

</div>

</div>

`;

});

}

// =====================
// البحث
// =====================

document.getElementById(
"searchInput"
).addEventListener(
"input",
function(){

const value =
this.value.toLowerCase();

const filtered =
allProducts.filter(product=>

(product.name || "")
.toLowerCase()
.includes(value)

);

renderProducts(filtered);

}
);

// =====================
// فتح نافذة
// =====================

window.openAddModal =
function(){

editId = null;

document.getElementById(
"modalTitle"
).innerHTML =
"إضافة منتج";

document.getElementById(
"productName"
).value = "";

document.getElementById(
"productPrice"
).value = "";

document.getElementById(
"productImage"
).value = "";

document.getElementById(
"productDescription"
).value = "";

document.getElementById(
"productModal"
).style.display = "flex";

};

// =====================
// غلق نافذة
// =====================

window.closeModal =
function(){

document.getElementById(
"productModal"
).style.display = "none";

};

// =====================
// حفظ منتج
// =====================

window.saveProduct =
async function(){

const name =
document.getElementById(
"productName"
).value.trim();

const price =
document.getElementById(
"productPrice"
).value.trim();

const image =
document.getElementById(
"productImage"
).value.trim();

const description =
document.getElementById(
"productDescription"
).value.trim();

if(!name || !price){

alert("اكمل البيانات");

return;

}

const data = {

name:name,
price:Number(price),
image:image,
description:description,

storeId:
currentUser.id,

storeName:
currentUser.storeName || "",

updatedAt:
Date.now()

};

if(editId){

await update(
ref(
db,
"store_products/" +
currentUser.id +
"/" +
editId
),
data
);

}else{

const newRef =
push(productsRef);

await set(
newRef,
{

...data,

createdAt:
Date.now(),

isHidden:false

}
);

}

closeModal();

};

// =====================
// تعديل
// =====================

window.editProduct =
function(id){

const product =
allProducts.find(
item => item.id === id
);

if(!product){
return;
}

editId = id;

document.getElementById(
"modalTitle"
).innerHTML =
"تعديل المنتج";

document.getElementById(
"productName"
).value =
product.name || "";

document.getElementById(
"productPrice"
).value =
product.price || "";

document.getElementById(
"productImage"
).value =
product.image || "";

document.getElementById(
"productDescription"
).value =
product.description || "";

document.getElementById(
"productModal"
).style.display = "flex";

};

// =====================
// اظهار واخفاء
// =====================

window.toggleProduct =
async function(id){

const product =
allProducts.find(
item => item.id === id
);

if(!product){
return;
}

await update(
ref(
db,
"store_products/" +
currentUser.id +
"/" +
id
),
{

isHidden:
!product.isHidden

}
);

};

// =====================
// حذف
// =====================

window.deleteProduct =
async function(id){

const ok =
confirm(
"هل تريد حذف المنتج؟"
);

if(!ok){
return;
}

await remove(
ref(
db,
"store_products/" +
currentUser.id +
"/" +
id
)
);

};

</script>

</body>

</html>