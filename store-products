<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0">

<title>
منتجات المتجر
</title>

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<link
href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;700;800&display=swap"
rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Cairo',sans-serif;
}

body{
background:#f5f6fa;
padding:15px;
padding-bottom:120px;
overflow-x:hidden;
}

.header{
background:
linear-gradient(
135deg,
#ff8800,
#ff5500
);

padding:22px;
border-radius:28px;
color:white;
margin-bottom:20px;

box-shadow:
0 8px 25px rgba(0,0,0,.12);
}

.header h2{
font-size:26px;
margin-bottom:8px;
}

.card{
background:white;
padding:18px;
border-radius:24px;
margin-bottom:18px;

box-shadow:
0 5px 18px rgba(0,0,0,.06);
}

.card-title{
font-size:18px;
font-weight:bold;
margin-bottom:15px;
color:#ff6600;
}

.input-group{
margin-bottom:15px;
}

.input-group label{
display:block;
margin-bottom:8px;
font-size:14px;
font-weight:bold;
}

.input-group input,
.input-group textarea{
width:100%;
padding:15px;
border-radius:16px;
border:1px solid #ddd;
background:#fafafa;
outline:none;
font-size:15px;
}

textarea{
resize:none;
height:110px;
}

.save-btn{
width:100%;
height:55px;
border:none;
border-radius:18px;

background:
linear-gradient(
135deg,
#00b894,
#00a383
);

color:white;
font-size:16px;
font-weight:bold;
cursor:pointer;
}

.products-container{
display:flex;
flex-direction:column;
gap:15px;
}

.product-card{
background:white;
padding:16px;
border-radius:24px;

display:flex;
gap:14px;
align-items:center;

box-shadow:
0 5px 18px rgba(0,0,0,.06);
}

.product-image{
width:90px;
height:90px;
border-radius:20px;
object-fit:cover;
background:#eee;
}

.product-info{
flex:1;
}

.product-info h3{
margin-bottom:6px;
}

.product-info p{
font-size:13px;
color:#666;
margin-bottom:5px;
}

.product-price{
font-size:18px;
font-weight:bold;
color:#ff6600;
margin-top:8px;
}

.actions{
display:flex;
flex-direction:column;
gap:10px;
}

.actions button{
width:100px;
height:42px;
border:none;
border-radius:14px;
color:white;
font-size:13px;
font-weight:bold;
cursor:pointer;
}

.edit-btn{
background:#2563eb;
}

.delete-btn{
background:#e53935;
}

.bottom-bar{
position:fixed;
bottom:0;
left:0;
right:0;
height:82px;
background:white;

display:flex;
justify-content:space-around;
align-items:center;

box-shadow:
0 -5px 18px rgba(0,0,0,.08);

z-index:9999;
}

.nav-item{
display:flex;
flex-direction:column;
align-items:center;
gap:5px;

font-size:13px;
font-weight:bold;

color:#888;
cursor:pointer;
}

.nav-item.active{
color:#ff8800;
}

.nav-item i{
font-size:22px;
}

</style>

</head>

<body>

<div class="header">

<h2>
إدارة المنتجات
</h2>

<p>
إضافة وتعديل منتجات المتجر
</p>

</div>

<div class="card">

<div class="card-title">
إضافة منتج جديد
</div>

<div class="input-group">

<label>
اسم المنتج
</label>

<input
type="text"
id="productName"
placeholder="اسم المنتج">

</div>

<div class="input-group">

<label>
السعر
</label>

<input
type="number"
id="productPrice"
placeholder="السعر بالدينار">

</div>

<div class="input-group">

<label>
رابط الصورة
</label>

<input
type="text"
id="productImage"
placeholder="رابط صورة المنتج">

</div>

<div class="input-group">

<label>
وصف المنتج
</label>

<textarea
id="productDescription"
placeholder="وصف المنتج"></textarea>

</div>

<button
class="save-btn"
onclick="saveProduct()">

حفظ المنتج

</button>

</div>

<div
id="productsContainer"
class="products-container"></div>

<div class="bottom-bar">

<div
class="nav-item"
onclick="window.location.href='store-dashboard.html'">

<i class="fa-solid fa-shop"></i>

<span>
الرئيسية
</span>

</div>

<div class="nav-item active">

<i class="fa-solid fa-box"></i>

<span>
المنتجات
</span>

</div>

<div
class="nav-item"
onclick="window.location.href='asca.html'">

<i class="fa-solid fa-user"></i>

<span>
الحساب
</span>

</div>

</div>

<script type="module">

import { db }
from "./firebase.js";

import {

ref,
push,
set,
onValue,
remove,
update

}

from
"https://www.gstatic.com/firebasejs/12.13.0/firebase-database.js";

const currentUser =
JSON.parse(
localStorage.getItem("user")
);

if(
!currentUser ||
currentUser.type !== "store"
){

window.location.replace(
"index.html"
);

}

const productsContainer =
document.getElementById(
"productsContainer"
);

let editingId = null;

// =====================
// عرض المنتجات
// =====================

onValue(
ref(
db,
"store_products/" + currentUser.id
),
(snapshot)=>{

productsContainer.innerHTML = "";

if(!snapshot.exists()){

productsContainer.innerHTML = `
<div style="
text-align:center;
padding:40px;
color:#777;
">
لا توجد منتجات
</div>
`;

return;

}

const products =
snapshot.val();

for(let key in products){

const product =
products[key];

productsContainer.innerHTML += `

<div class="product-card">

<img
src="${product.image || 'product.png'}"
class="product-image"
onerror="this.src='product.png'">

<div class="product-info">

<h3>
${product.name || ""}
</h3>

<p>
${product.description || ""}
</p>

<div class="product-price">

${Number(product.price || 0)
.toLocaleString()} د.ع

</div>

</div>

<div class="actions">

<button
class="edit-btn"
onclick="editProduct('${key}')">

تعديل

</button>

<button
class="delete-btn"
onclick="deleteProduct('${key}')">

حذف

</button>

</div>

</div>

`;

}

}
);

// =====================
// حفظ المنتج
// =====================

window.saveProduct =
async function(){

const name =
document.getElementById(
"productName"
).value.trim();

const price =
document.getElementById(
"productPrice"
).value.trim();

const image =
document.getElementById(
"productImage"
).value.trim();

const description =
document.getElementById(
"productDescription"
).value.trim();

if(
!name ||
!price
){

alert("اكمل البيانات");

return;

}

const productData = {

name:name,

price:Number(price),

image:image || "",

description:description || "",

storeId:
currentUser.id,

storeName:
currentUser.store_name || "",

status:"active",

createdAt:
Date.now()

};

if(editingId){

await update(
ref(
db,
"store_products/" +
currentUser.id +
"/" +
editingId
),
productData
);

alert("تم تعديل المنتج");

editingId = null;

}else{

const newRef =
push(
ref(
db,
"store_products/" +
currentUser.id
)
);

await set(
newRef,
productData
);

alert("تم اضافة المنتج");

}

document.getElementById(
"productName"
).value = "";

document.getElementById(
"productPrice"
).value = "";

document.getElementById(
"productImage"
).value = "";

document.getElementById(
"productDescription"
).value = "";

};

// =====================
// تعديل
// =====================

window.editProduct =
async function(productId){

editingId = productId;

onValue(
ref(
db,
"store_products/" +
currentUser.id +
"/" +
productId
),
(snapshot)=>{

if(!snapshot.exists()){
return;
}

const product =
snapshot.val();

document.getElementById(
"productName"
).value =
product.name || "";

document.getElementById(
"productPrice"
).value =
product.price || "";

document.getElementById(
"productImage"
).value =
product.image || "";

document.getElementById(
"productDescription"
).value =
product.description || "";

},
{
onlyOnce:true
}
);

window.scrollTo({
top:0,
behavior:"smooth"
});

};

// =====================
// حذف
// =====================

window.deleteProduct =
async function(productId){

const confirmDelete =
confirm("حذف المنتج ؟");

if(!confirmDelete){
return;
}

await remove(
ref(
db,
"store_products/" +
currentUser.id +
"/" +
productId
)
);

alert("تم حذف المنتج");

};

</script>

</body>

</html>